; Engine configuration file.
; It's best edited using the editor UI and not directly,
; since the parameters that go here are not all obvious.
;
; Format:
;   [section] ; section goes between []
;   param=value ; assign values to parameters

config_version=5

[animation]

compatibility/default_parent_skeleton_in_mesh_instance_3d=true

[application]

config/name="From Nothing"
config/description="ERROR: ABANDONED PROJECT"
run/main_scene="uid://wxyd4t70safx"
config/features=PackedStringArray("4.6", "GL Compatibility")
config/icon="uid://qw0xkofp2wkr"

[audio]

buses/default_bus_layout="uid://daa5thw8lwmkt"

[autoload]

GlobalVariables="*uid://b2cdiqop0yw8j"
MusicController="*uid://d2wqjrvgx1of7"
GameOver="*uid://4tqwbavm5yiy"
TheCamera="*uid://d15fdufr1dj2o"
SetPlayerPosition="*uid://b6btcxhhsqehh"
PauseMenu="*uid://6c82mhxr50dl"
SettingsPopup="*uid://cvbba0aml7aep"
DialogueManager="*uid://c3rodes2l3gxb"
CutsceneManager="*uid://mvim6xmmukaa"
TalkScenes="*uid://bwd5flueasuej"
SaveLoad="*uid://tdqm0x7o8txp"

[dialogue_manager]

runtime/state_autoload_shortcuts=["res://scripts/global_varibles.gd", "res://scenes/player.tscn", "res://scripts/cutscene_manager.gd"]
runtime/warn_about_method_property_or_signal_name_conflicts=true
editor/wrap_long_lines=true

[display]

window/size/resizable=false
window/subwindows/embed_subwindows=false
window/stretch/mode="canvas_items"

[editor_plugins]

enabled=PackedStringArray("res://addons/dialogue_manager/plugin.cfg")

